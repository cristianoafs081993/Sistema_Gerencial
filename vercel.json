{
    "framework": "vite",
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/api-transparencia/:path*",
            "destination": "https://api.portaldatransparencia.gov.br/:path*"
        },
        {
            "source": "/api-contratos/:path*",
            "destination": "https://contratos.comprasnet.gov.br/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
